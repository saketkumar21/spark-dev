# =============================================================================
# spark-dev Environment Configuration
# Copy to .env and adjust as needed: cp .env.example .env
# =============================================================================

# ── Spark Connect ────────────────────────────────────────────────────────────
# URL for notebooks to connect to Spark Connect Server (Docker)
# Set to empty to use local embedded Spark instead
SPARK_REMOTE=sc://localhost:15002
SPARK_CONF_DIR=./conf

# ── Kafka ────────────────────────────────────────────────────────────────────
# External: used by producer scripts on your laptop
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ── Ports ────────────────────────────────────────────────────────────────────
SPARK_CONNECT_PORT=15002
SPARK_THRIFT_PORT=10000
SPARK_UI_PORT=4040
SPARK_HISTORY_PORT=18080
JUPYTER_PORT=8888
KAFKA_UI_PORT=8080
KAFKA_EXTERNAL_PORT=29092

# ── dbt ──────────────────────────────────────────────────────────────────────
# Connection config used by dbt/profiles.yml via env_var()
DBT_SPARK_HOST=localhost
DBT_SPARK_PORT=10000

# ── Jupyter ──────────────────────────────────────────────────────────────────
# Leave empty for no authentication (local dev only)
JUPYTER_TOKEN=
