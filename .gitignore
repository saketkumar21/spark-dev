# Python
__pycache__/
*.py[oc]
*.egg-info
build/
dist/
wheels/
.venv/

# Environment
.python-version
.env

# Spark generated data (all runtime artifacts live in .tmp/)
.tmp/
logs/

# Streaming input (generated by producers)
app/data/streaming_input/

# Keep source data tracked
!app/data/source/
!app/data/target/

# dbt artifacts
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.env
dbt/.user.yml

# dbt-spark-qualify build artifacts
dbt-spark-qualify/build/
dbt-spark-qualify/*.egg-info

# Airflow runtime (logs, db, etc.)
airflow/.airflow_home/

# Jupyter checkpoints
.ipynb_checkpoints/

# Claude Code (session state)
.claude/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db
